# ═══════════════════════════════════════════════════════
# VARIABLES ENVIRONNEMENT - URBANFIX AI
# ═══════════════════════════════════════════════════════
# Copiez ce fichier vers .env et remplissez vos clés API

# ═══════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════
APP_NAME=UrbanFix AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BASE_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════
# BASE DE DONNÉES
# ═══════════════════════════════════════════════════════
# SQLite (développement)
DATABASE_URL=sqlite:///./urbanfix.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/urbanfix_db

# ═══════════════════════════════════════════════════════
# SÉCURITÉ
# ═══════════════════════════════════════════════════════
# Générez une clé secrète forte avec: openssl rand -hex 32
SECRET_KEY=changez-cette-cle-secrete-en-production-utilisez-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ═══════════════════════════════════════════════════════
# APIs SERVICES EXTERNES
# ═══════════════════════════════════════════════════════

# Groq API (Llama 3.1) - GRATUIT
# Obtenez votre clé sur: https://console.groq.com/keys
GROQ_API_KEY=votre_cle_groq_ici

# Hugging Face (modèles IA)
# Obtenez votre token sur: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=votre_token_hf_ici

# OpenAI (optionnel - GPT-4 Vision)
# OPENAI_API_KEY=votre_cle_openai_ici

# Replicate (optionnel - alternative SDXL cloud)
# REPLICATE_API_KEY=votre_cle_replicate_ici

# Mapbox (cartes)
# MAPBOX_TOKEN=votre_token_mapbox_ici

# Cloudinary (stockage images cloud)
# CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=votre_api_key
# CLOUDINARY_API_SECRET=votre_api_secret

# ═══════════════════════════════════════════════════════
# CONFIGURATION IA/ML
# ═══════════════════════════════════════════════════════

# Chemins modèles (locaux)
YOLO_MODEL_PATH=./models/yolo_road_damage_best.pt
SDXL_LORA_PATH=./models/lora_tunisia_urban.safetensors

# Répertoires
MODELS_DIR=./models
OUTPUT_DIR=./outputs
UPLOAD_DIR=./uploads
TEMP_DIR=./temp

# Paramètres détection
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# Paramètres génération images
SDXL_NUM_INFERENCE_STEPS=30
SDXL_GUIDANCE_SCALE=7.5
SDXL_NUM_SCENARIOS=3

# Paramètres Llama/Groq
GROQ_MODEL_ID=llama-3.1-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=2000

# Paramètres audio
BARK_VOICE_PRESET=v2/fr_speaker_6
BARK_SAMPLE_RATE=24000

# Paramètres vidéo
SVD_NUM_FRAMES=25
SVD_FPS=25
VIDEO_OUTPUT_FPS=25

# ═══════════════════════════════════════════════════════
# UPLOAD FICHIERS
# ═══════════════════════════════════════════════════════
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=[".jpg", ".jpeg", ".png", ".webp"]
